@model Inventory.ViewModel.InvoiceViewModel.InvoiceTypeListViewModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Update</h1>
<h4>InvoiceType</h4>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Update" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Hidden ID -->
            <input type="hidden" asp-for="InvoiceTypeId" />

            <div class="form-group">
                <label asp-for="InvoiceTypeName" class="control-label"></label>
                <input asp-for="InvoiceTypeName" class="form-control" />
                <span asp-validation-for="InvoiceTypeName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>